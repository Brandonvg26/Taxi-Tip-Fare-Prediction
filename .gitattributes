# Default: normalize all text files to LF
* text=auto eol=lf

# Force these to always be LF (critical for Docker/Linux)
Dockerfile text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Notebooks — LF to avoid JSON diffs
*.ipynb text eol=lf

# Windows-specific files can stay CRLF if needed
*.bat text eol=crlf
*.cmd text eol=crlf